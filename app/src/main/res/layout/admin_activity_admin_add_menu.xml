<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/biru_tua"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="25dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back_white"
            android:padding="8dp"
            android:contentDescription="Kembali"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tambah Menu"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/ivBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilih Tenant"
                android:textColor="@color/dark_900"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerTenant"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background" />

            <EditText
                android:id="@+id/etMenuNama"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/edit_text_background"
                android:hint="Nama Menu"
                android:paddingLeft="14dp"
                android:inputType="text" />

            <EditText
                android:id="@+id/etMenuDeskripsi"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_background"
                android:gravity="top"
                android:hint="Deskripsi"
                android:inputType="textMultiLine"
                android:paddingLeft="14dp"
                android:paddingTop="14dp" />

            <EditText
                android:id="@+id/etMenuHarga"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_background"
                android:hint="Harga (angka)"
                android:inputType="number"
                android:paddingLeft="14dp" />

            <EditText
                android:id="@+id/etMenuGambar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_background"
                android:hint="URL Gambar (opsional)"
                android:inputType="textUri"
                android:paddingLeft="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tambahan (opsional)"
                android:textColor="@color/dark_900"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <EditText
                android:id="@+id/etTambahanNama"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background"
                android:hint="Nama tambahan (contoh: Pedas)"
                android:inputType="text"
                android:paddingLeft="14dp" />

            <EditText
                android:id="@+id/etTambahanHarga"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background"
                android:hint="Harga tambahan (0 jika gratis)"
                android:inputType="number"
                android:paddingLeft="14dp" />

            <Button
                android:id="@+id/btnTambahTambahan"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:background="@drawable/bg_secondary_button"
                android:text="+ Tambahkan"
                android:textColor="@color/blue_700"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTambahanList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tambahan: "
                android:textColor="@color/dark_700"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnSimpan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/button_biru"
        android:text="Simpan Menu"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        android:textStyle="bold" />
</LinearLayout>