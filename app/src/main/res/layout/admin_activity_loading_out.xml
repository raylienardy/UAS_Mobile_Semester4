<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:background="@drawable/bg_header"
        android:gravity="center_vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <TextView
            android:id="@+id/btn_back_loading"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_nav_active"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/blue_700"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading Out"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Pindahkan tenant ke lokasi lain"
                android:textColor="@color/blue_100"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pilih Tenant"
            android:textColor="@color/dark_900"
            android:textStyle="bold" />
        <Spinner
            android:id="@+id/spinner_tenant"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/edit_text_background" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Pilih Lokasi Baru"
            android:textColor="@color/dark_900"
            android:textStyle="bold" />
        <Spinner
            android:id="@+id/spinner_lokasi"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/edit_text_background" />

        <Button
            android:id="@+id/btn_pindah_tenant"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/button_biru"
            android:text="Pindahkan Tenant"
            android:textColor="@color/white"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:textStyle="bold" />


    </LinearLayout>
</LinearLayout>