<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tv_menu_readonly_nama"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nasi Goreng"
        android:textColor="@color/dark_900"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_menu_readonly_deskripsi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Deskripsi menu"
        android:textColor="@color/dark_700"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_menu_readonly_harga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Rp 20.000"
        android:textColor="@color/blue_700"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_menu_readonly_tenant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Tenant: T0001"
        android:textColor="@color/dark_700"
        android:textSize="12sp" />
</LinearLayout>