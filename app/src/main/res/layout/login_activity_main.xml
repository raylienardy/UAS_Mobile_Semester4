<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biru">

    <!-- LOGO (pojok kanan atas, sebagian keluar layar) -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="270dp"
        android:layout_height="298dp"
        android:src="@drawable/logo_unm_putih"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="231dp"
        app:layout_constraintTop_toTopOf="parent"
        android:translationY="-71dp"
        tools:ignore="ContentDescription" />

    <!-- TITLE -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FoodCourt Go"
        android:textColor="@color/putih_banget"
        android:textSize="48sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.3"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="235dp" />

    <!-- SUBTITLE -->
    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Makan mudah, pesan cepat"
        android:textColor="@color/biru_tua"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/title"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/title"
        android:layout_marginTop="8dp" />

    <!-- BUTTON SIGNUP (warna biru tua) -->
    <Button
        android:id="@+id/btnSignup"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Sign up"
        android:textColor="@color/putih_banget"
        android:textStyle="bold"
        android:textSize="18sp"
        android:background="@drawable/button_biru"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"/>

    <!-- LOGIN LINK (dipisah warnanya) -->
    <LinearLayout
        android:id="@+id/linkContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/btnSignup"
        app:layout_constraintStart_toStartOf="@id/btnSignup"
        app:layout_constraintEnd_toEndOf="@id/btnSignup"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/tvAlready"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account? "
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Login"
            android:textColor="#355872"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- DEKORASI BLOB (seperti awan) -->
    <!-- Blob 1 -->
    <View
        android:layout_width="200dp"
        android:layout_height="120dp"
        android:background="@drawable/shape_blob"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="315dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="520dp"
        android:translationX="-40dp"
        android:translationY="40dp" />

    <!-- Blob 2 -->
    <View
        android:layout_width="220dp"
        android:layout_height="140dp"
        android:background="@drawable/shape_blob"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="175dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="560dp"
        android:translationX="40dp"
        android:translationY="60dp" />

    <!-- Blob 3 (sebagian keluar kiri) -->
    <View
        android:layout_width="156dp"
        android:layout_height="88dp"
        android:background="@drawable/shape_blob"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="0dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="489dp"
        android:translationX="-60dp"
        android:translationY="40dp" />

    <!-- Blob 4 (sebagian keluar kiri) -->
    <View
        android:layout_width="175dp"
        android:layout_height="85dp"
        android:background="@drawable/shape_blob"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="0dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="540dp"
        android:translationX="-115dp"
        android:translationY="30dp" />

</androidx.constraintlayout.widget.ConstraintLayout>