<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tv_pesanan_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="#ORD-001"
        android:textColor="@color/dark_900"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_pesanan_tanggal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="20 Mei 2024, 10:25"
        android:textColor="@color/dark_700"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_pesanan_total"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rp 25.000"
        android:textColor="@color/dark_900"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />
</LinearLayout>