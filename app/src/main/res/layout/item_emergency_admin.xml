<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tv_emergency_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Budi (customer)"
        android:textColor="@color/dark_900"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_emergency_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Pesanan belum datang"
        android:textColor="@color/dark_700"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_emergency_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Meja: A03"
        android:textColor="@color/blue_700"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_emergency_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="10:25"
        android:textColor="@color/gray_400"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/btn_resolve_emergency"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_secondary_button"
        android:gravity="center"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:text="Tandai Selesai"
        android:textColor="@color/blue_700"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>