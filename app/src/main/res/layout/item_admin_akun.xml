<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <!-- Baris atas: Nama dan Role -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_akun_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Budi"
            android:textColor="@color/dark_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_akun_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="customer"
            android:textColor="@color/blue_700"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Username -->
    <TextView
        android:id="@+id/tv_akun_username"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@budi"
        android:textColor="@color/dark_700"
        android:textSize="13sp" />

    <!-- Email -->
    <TextView
        android:id="@+id/tv_akun_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="budi@gmail.com"
        android:textColor="@color/dark_700"
        android:textSize="13sp" />

    <!-- Status dan Tombol Aksi (Edit & Hapus) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_akun_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Aktif"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_edit_akun"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit"
            android:textColor="@color/blue_700"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_delete_akun"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hapus"
            android:textColor="@color/red_500"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>