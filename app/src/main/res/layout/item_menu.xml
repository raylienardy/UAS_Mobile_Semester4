<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Gambar menu (kanan) -->
        <ImageView
            android:id="@+id/ivMenuImage"
            android:layout_width="86dp"
            android:layout_height="65dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:scaleType="centerCrop"
            android:contentDescription="Foto menu"
            android:background="@drawable/shape_menu_image" />

        <!-- Nama menu -->
        <TextView
            android:id="@+id/tvMenuNama"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Nama Menu"
            android:textColor="@color/biru_tua"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Deskripsi -->
        <TextView
            android:id="@+id/tvMenuDeskripsi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvMenuNama"
            android:layout_marginTop="2dp"
            android:layout_toStartOf="@id/ivMenuImage"
            android:layout_alignStart="@id/tvMenuNama"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Deskripsi singkat"
            android:textColor="#666666"
            android:textSize="11sp" />

        <!-- Harga -->
        <TextView
            android:id="@+id/tvMenuHarga"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvMenuDeskripsi"
            android:layout_marginTop="8dp"
            android:text="Rp0"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Container untuk tombol Tambah dan kontrol kuantitas -->
        <FrameLayout
            android:id="@+id/llQuantityContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/ivMenuImage"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="8dp">

            <!-- Tombol Tambah (awal) -->
            <TextView
                android:id="@+id/btnTambah"
                android:layout_width="84dp"
                android:layout_height="30dp"
                android:text="Tambah"
                android:textColor="#2F5C85"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/btn_tambah_background"
                android:clickable="true"
                android:focusable="true"
                android:visibility="visible" />

            <!-- Kontrol kuantitas (awal GONE) -->
            <LinearLayout
                android:id="@+id/llQuantityControl"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone"
                android:background="@drawable/btn_tambah_background">

                <TextView
                    android:id="@+id/btnMinus"
                    android:layout_width="30dp"
                    android:layout_height="match_parent"
                    android:text="–"
                    android:textColor="#2F5C85"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="30dp"
                    android:layout_height="match_parent"
                    android:text="1"
                    android:textColor="#2F5C85"
                    android:textSize="15sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/btnPlus"
                    android:layout_width="30dp"
                    android:layout_height="match_parent"
                    android:text="+"
                    android:textColor="#2F5C85"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </FrameLayout>
    </RelativeLayout>
</androidx.cardview.widget.CardView>