<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/page_detail_pesanan"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/header_detail_pesanan"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:background="@drawable/bg_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <TextView
            android:id="@+id/btn_back_detail"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_nav_active"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/blue_700"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detail Pesanan"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_detail_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Informasi lengkap pesanan"
                android:textColor="@color/blue_100"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_detail_pesanan"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="18dp"
        android:paddingTop="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:id="@+id/container_detail_pesanan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/card_detail_identity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_blue"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tv_detail_order_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ID Pesanan: #001"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_table"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Meja A-03 • 10:25"
                    android:textColor="@color/blue_100"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/chip_detail_status"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_chip_pending"
                    android:gravity="center"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:text="Pending"
                    android:textColor="@color/yellow_700"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_detail_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_detail_info_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Informasi Pesanan"
                    android:textColor="@color/dark_900"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_tenant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Tenant: Ayam Geprek Bu Sari"
                    android:textColor="@color/dark_700"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_detail_customer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Customer: Pengunjung Meja A-03"
                    android:textColor="@color/dark_700"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_detail_payment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Pembayaran: QRIS"
                    android:textColor="@color/dark_700"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_detail_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_detail_items_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Item Pesanan"
                    android:textColor="@color/dark_900"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_item_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Ayam Geprek   1 x Rp 20.000"
                    android:textColor="@color/dark_700"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_detail_item_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Es Teh Manis   1 x Rp 5.000"
                    android:textColor="@color/dark_700"
                    android:textSize="14sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/gray_200" />

                <TextView
                    android:id="@+id/tv_detail_total"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:text="Total: Rp 25.000"
                    android:textColor="@color/blue_700"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_detail_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_update_status_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Update Status"
                    android:textColor="@color/dark_900"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_detail_process"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginRight="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/button_biru"
                        android:gravity="center"
                        android:text="Diproses"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btn_detail_cancel"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginLeft="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_danger_button"
                        android:gravity="center"
                        android:text="Batalkan"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_detail_done"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_secondary_button"
                    android:gravity="center"
                    android:text="Tandai Selesai"
                    android:textColor="@color/blue_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>