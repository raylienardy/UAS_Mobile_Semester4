<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/page_tenant_order_detail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/toolbar_tenant_order_detail"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">

        <TextView
            android:id="@+id/btn_back_order_detail"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="Back"
            android:textColor="@color/dark_900"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_order_detail_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Detail Pesanan"
            android:textColor="@color/dark_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="42dp"
            android:layout_height="42dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_tenant_order_detail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:id="@+id/container_order_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/card_detail_order_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_detail_order_number"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="#ORD-001"
                        android:textColor="@color/dark_900"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/chip_detail_order_status"
                        android:layout_width="74dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_chip_pending"
                        android:gravity="center"
                        android:text="Pending"
                        android:textColor="@color/yellow_700"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_detail_table_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Meja / Kode                         A12345"
                    android:textColor="@color/dark_700"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_detail_order_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Waktu                              20 Mei 2024, 10:25"
                    android:textColor="@color/dark_700"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_detail_menu_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_detail_menu_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Daftar Menu"
                    android:textColor="@color/dark_900"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_item_1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:text="Nasi Goreng          1x          Rp 15.000"
                    android:textColor="@color/dark_900"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_detail_item_2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:text="Es Teh Manis        2x          Rp 10.000"
                    android:textColor="@color/dark_900"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/gray_200" />

                <TextView
                    android:id="@+id/tv_detail_subtotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="right"
                    android:text="Subtotal        Rp 25.000"
                    android:textColor="@color/dark_900"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_detail_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_detail_note_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Catatan"
                    android:textColor="@color/dark_900"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_note_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Tidak ada catatan"
                    android:textColor="@color/dark_700"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_process_order_detail"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/button_biru"
                android:gravity="center"
                android:text="Proses Pesanan"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_cancel_order_detail"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline_red_button"
                android:gravity="center"
                android:text="Batalkan Pesanan"
                android:textColor="@color/red_500"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:id="@+id/bottom_nav_tenant_dashboard"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/bg_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp">

        <TextView
            android:id="@+id/nav_tenant_dashboard"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Dashboard"
            android:textColor="@color/dark_700"
            android:textSize="11sp"/>

        <TextView
            android:id="@+id/nav_tenant_orders"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Pesanan"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/nav_tenant_menu"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_margin="3dp"
            android:background="@drawable/bg_nav_active"
            android:layout_weight="1"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Menu"
            android:textColor="@color/blue_700"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/nav_tenant_profile"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Profil"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>