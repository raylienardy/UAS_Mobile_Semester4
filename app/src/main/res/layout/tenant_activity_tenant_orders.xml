<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/page_tenant_orders"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/toolbar_tenant_orders"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">


        <TextView
            android:id="@+id/btn_back_orders"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="Back"
            android:textColor="@color/dark_900"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_orders_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Pesanan"
            android:textColor="@color/dark_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/filter_orders_today"
            android:layout_width="72dp"
            android:layout_height="36dp"
            android:background="@drawable/edit_text_background"
            android:gravity="center"
            android:text="Hari Ini"
            android:textColor="@color/dark_900"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/order_filter_tabs"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">

        <TextView
            android:id="@+id/tab_orders_all"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_nav_active"
            android:gravity="center"
            android:text="Semua"
            android:textColor="@color/blue_700"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_orders_pending"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginLeft="6dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Pending"
            android:textColor="@color/dark_700"
            android:textSize="12sp" />


        <TextView
            android:id="@+id/tab_orders_process"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginLeft="6dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Diproses"
            android:textColor="@color/dark_700"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tab_orders_done"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginLeft="6dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Selesai"
            android:textColor="@color/dark_700"
            android:textSize="12sp" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_tenant_orders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingLeft="18dp"
        android:paddingTop="8dp"
        android:paddingRight="18dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:id="@+id/container_tenant_orders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tenant_orders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tv_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum ada pesanan"
                android:textColor="@color/dark_700"
                android:textSize="16sp"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_nav_tenant_orders"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/bg_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp">

        <TextView
            android:id="@+id/nav_tenant_dashboard"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Dashboard"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/nav_tenant_orders"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:background="@drawable/bg_nav_active"
            android:gravity="center"
            android:text="Pesanan"
            android:textColor="@color/blue_700"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nav_tenant_menu"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Menu"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/nav_tenant_profile"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Profil"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

    </LinearLayout>
</LinearLayout>