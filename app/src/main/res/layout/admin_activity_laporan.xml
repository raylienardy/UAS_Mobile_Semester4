<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/page_laporan"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <!-- Header dengan tombol kembali -->
    <LinearLayout
        android:id="@+id/header_laporan"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:background="@drawable/bg_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <TextView
            android:id="@+id/btn_back_laporan"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_nav_active"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/blue_700"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Laporan"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Statistik penjualan dan performa tenant"
                android:textColor="@color/blue_100"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_laporan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="18dp">

        <LinearLayout
            android:id="@+id/container_laporan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Filter -->
            <LinearLayout
                android:id="@+id/card_laporan_filter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:elevation="2dp"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:id="@+id/filter_daily"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginRight="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_nav_active"
                    android:gravity="center"
                    android:text="Harian"
                    android:textColor="@color/blue_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/filter_monthly"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:text="Bulanan"
                    android:textColor="@color/dark_700"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/filter_yearly"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginLeft="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:text="Tahunan"
                    android:textColor="@color/dark_700"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Ringkasan Pendapatan & Pesanan -->
            <LinearLayout
                android:id="@+id/row_laporan_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/card_income_summary"
                    android:layout_width="0dp"
                    android:layout_height="108dp"
                    android:layout_marginRight="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_blue"
                    android:elevation="3dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pendapatan"
                        android:textColor="@color/blue_100"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_report_income"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Rp 0"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card_order_summary"
                    android:layout_width="0dp"
                    android:layout_height="108dp"
                    android:layout_marginLeft="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:elevation="3dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pesanan"
                        android:textColor="@color/dark_700"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_report_order"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0"
                        android:textColor="@color/dark_900"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Grafik Penjualan -->
            <LinearLayout
                android:id="@+id/card_sales_chart"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_chart_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Grafik Penjualan"
                    android:textColor="@color/dark_900"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/chart_container"
                    android:layout_width="match_parent"
                    android:layout_height="170dp"
                    android:layout_marginTop="18dp"
                    android:gravity="bottom"
                    android:orientation="horizontal" />
            </LinearLayout>

            <!-- Menu Terlaris -->
            <LinearLayout
                android:id="@+id/card_top_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_top_menu_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Menu Terlaris"
                    android:textColor="@color/dark_900"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_top_menu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- Tombol Export Data -->
            <Button
                android:id="@+id/btn_export_report"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/button_biru"
                android:text="Export Data"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>