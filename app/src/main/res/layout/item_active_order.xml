<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_order_status"
            android:tint="@color/blue_700" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvActiveTenantName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tenant Name"
                android:textStyle="bold"
                android:textColor="@color/dark_900" />

            <TextView
                android:id="@+id/tvActiveOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#P001"
                android:textSize="12sp"
                android:textColor="@color/dark_700" />

            <TextView
                android:id="@+id/tvActiveOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menunggu konfirmasi"
                android:textSize="12sp"
                android:textColor="@color/blue_700" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvActiveOrderTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp25.000"
            android:textStyle="bold"
            android:textColor="@color/dark_900" />

    </LinearLayout>
</androidx.cardview.widget.CardView>