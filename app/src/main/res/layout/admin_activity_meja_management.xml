<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <!-- Header (sama seperti sebelumnya) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:background="@drawable/bg_header"
        android:gravity="center_vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <TextView
            android:id="@+id/btn_back_meja"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_nav_active"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/blue_700"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manajemen Meja"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Atur meja dan QR code"
                android:textColor="@color/blue_100"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Daftar Meja -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_meja_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false" />

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_meja"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_margin="16dp"
        android:src="@drawable/ic_plus"
        app:backgroundTint="@color/biru_tua"
        app:tint="@null" />   <!-- tambahkan baris ini -->

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:id="@+id/bottom_nav_meja"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/bg_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <TextView
            android:id="@+id/nav_dashboard"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Home"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/nav_tenant"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Tenant"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/nav_menu"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Menu"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

        <!-- Menu Meja (aktif) -->
        <TextView
            android:id="@+id/nav_meja"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:background="@drawable/bg_nav_active"
            android:gravity="center"
            android:text="Meja"
            android:textColor="@color/blue_700"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nav_pesanan"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Order"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btn_quick_akun"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Akun"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>