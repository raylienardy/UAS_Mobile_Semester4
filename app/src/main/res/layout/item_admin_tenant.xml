<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_tenant_nama"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nama Tenant"
            android:textColor="@color/dark_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_tenant_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="active"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_tenant_kategori"
            android:layout_width="347dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Kategori: Makanan"
            android:textColor="@color/dark_700"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/iv_edit_lokasi"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_edit_location"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_toggle_status"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_secondary_button"
            android:text="Toggle Status"
            android:textColor="@color/blue_700"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="@null"
            app:backgroundTint="@null" />


        <Button
            android:id="@+id/btn_assign_akun"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/button_biru"
            android:text="Assign Akun"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:layout_marginEnd="6dp"
            android:backgroundTint="@null"
            app:backgroundTint="@null" />


        <Button
            android:id="@+id/btn_move_location"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_secondary_button"
            android:text="Pindah Lokasi"
            android:textColor="@color/blue_700"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="@null"
            app:backgroundTint="@null" />
    </LinearLayout>
</LinearLayout>