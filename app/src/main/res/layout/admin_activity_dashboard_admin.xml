<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/page_dashboard_admin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header_dashboard"
        android:layout_width="match_parent"
        android:layout_height="132dp"
        android:background="@drawable/bg_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_dashboard_greeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Halo, Admin"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_dashboard_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Pantau operasional foodcourt hari ini"
                android:textColor="@color/blue_100"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_profile_shortcut"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:text="A"
            android:textColor="@color/blue_700"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_dashboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="18dp">

        <LinearLayout
            android:id="@+id/container_dashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Row 1: Total Pesanan & Pendapatan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/card_total_orders"
                    android:layout_width="0dp"
                    android:layout_height="124dp"
                    android:layout_marginRight="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_blue"
                    android:elevation="3dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Total Pesanan"
                        android:textColor="@color/white"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_total_orders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="128"
                        android:textColor="@color/white"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="+12% dari kemarin"
                        android:textColor="@color/white"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card_revenue"
                    android:layout_width="0dp"
                    android:layout_height="124dp"
                    android:layout_marginLeft="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:elevation="3dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pendapatan"
                        android:textColor="@color/dark_700"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_total_revenue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Rp 3,2 jt"
                        android:textColor="@color/dark_900"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hari ini"
                        android:textColor="@color/gray_400"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: Tenant Aktif & Menu Tersedia -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/card_active_tenant"
                    android:layout_width="0dp"
                    android:layout_height="96dp"
                    android:layout_marginRight="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tenant Aktif"
                        android:textColor="@color/dark_700"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_active_tenant"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="12"
                        android:textColor="@color/dark_900"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card_menu_count"
                    android:layout_width="0dp"
                    android:layout_height="96dp"
                    android:layout_marginLeft="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Menu Tersedia"
                        android:textColor="@color/dark_700"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_menu_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="86"
                        android:textColor="@color/dark_900"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3: Jumlah Meja -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/card_table_count"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_card"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Jumlah Meja"
                        android:textColor="@color/dark_700"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_table_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="@color/dark_900"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Aksi Cepat -->
            <TextView
                android:id="@+id/tv_quick_action_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Aksi Cepat"
                android:textColor="@color/dark_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/row_quick_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_quick_tenant"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginRight="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary_button"
                    android:gravity="center"
                    android:text="+ Tenant"
                    android:textColor="@color/blue_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_quick_menu"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginLeft="6dp"
                    android:layout_marginRight="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary_button"
                    android:gravity="center"
                    android:text="+ Menu"
                    android:textColor="@color/blue_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_quick_report"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginLeft="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary_button"
                    android:gravity="center"
                    android:text="Laporan"
                    android:textColor="@color/blue_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Pesanan Terbaru -->
            <TextView
                android:id="@+id/tv_recent_order_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Pesanan Terbaru"
                android:textColor="@color/dark_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_recent_orders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:padding="16dp" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_nav_dashboard"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/bg_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <TextView
            android:id="@+id/nav_dashboard"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:background="@drawable/bg_nav_active"
            android:gravity="center"
            android:text="Home"
            android:textColor="@color/blue_700"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nav_tenant"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Tenant"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/nav_menu"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Menu"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btn_quick_meja"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Meja"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/nav_pesanan"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Order"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btn_quick_akun"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Akun"
            android:textColor="@color/dark_700"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>