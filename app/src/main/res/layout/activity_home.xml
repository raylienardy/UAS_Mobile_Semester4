<?xml version="1.0" encoding="utf-8"?>
<!-- DrawerLayout WAJIB jadi root agar sidebar bisa muncul dari samping -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

        <!-- Navbar biru -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/navbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/biru_tua"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="25dp"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Hamburger icon — klik ini buka sidebar -->
            <ImageView
                android:id="@+id/ivMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_menu"
                android:padding="8dp"
                android:contentDescription="Menu"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Search bar -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:hint="Cari tenant..."
                android:textColorHint="@color/biru_tua"
                android:textColor="@color/biru_tua"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/edit_text_background"
                android:inputType="text"
                android:layout_marginStart="16dp"
                app:layout_constraintStart_toEndOf="@id/ivMenu"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Empty state (muncul kalau belum ada tenant) -->
        <LinearLayout
            android:id="@+id/llEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/navbar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum ada tenant ditambahkan"
                android:textColor="@color/biru_tua"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tekan tombol + untuk menambahkan tenant"
                android:textColor="#888888"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="20dp" />
        </LinearLayout>

        <!-- RecyclerView daftar tenant -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTenants"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingTop="12dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/navbar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />



    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ============================================================
         SIDEBAR / NAVIGATION DRAWER
         layout_gravity="start" = muncul dari kiri
         ============================================================ -->
    <LinearLayout
        android:id="@+id/navSidebar"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <!-- Header sidebar (latar biru tua) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/biru_tua"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <!-- Avatar / inisial user -->
            <TextView
                android:id="@+id/tvSidebarAvatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="U"
                android:textColor="@color/biru_tua"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@color/putih_banget"
                android:layout_marginBottom="12dp" />

            <!-- Nama user -->
            <TextView
                android:id="@+id/tvSidebarNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama User"
                android:textColor="@color/putih_banget"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- User ID -->
            <TextView
                android:id="@+id/tvSidebarUserId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID: A0001"
                android:textColor="#BBDEFB"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Scrollable menu items -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <!-- Item: Beranda -->
                <LinearLayout
                    android:id="@+id/menuBeranda"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_compass"
                        android:tint="@color/biru_tua"
                        android:contentDescription="Beranda" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Beranda"
                        android:textColor="@color/biru_tua"
                        android:textSize="15sp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <!-- Item: Profil Saya -->
                <LinearLayout
                    android:id="@+id/menuProfil"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        android:tint="@color/biru_tua"
                        android:contentDescription="Profil" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profil Saya"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <!-- Item: Tenant Tersimpan -->
                <LinearLayout
                    android:id="@+id/menuTenantTersimpan"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_save"
                        android:tint="@color/biru_tua"
                        android:contentDescription="Tenant Tersimpan" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tenant Tersimpan"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <!-- Item: Kategori -->
                <LinearLayout
                    android:id="@+id/menuKategori"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:tint="@color/biru_tua"
                        android:contentDescription="Kategori" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kategori"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <!-- Garis pemisah -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp" />

                <!-- Item: Tentang Aplikasi -->
                <LinearLayout
                    android:id="@+id/menuTentang"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        android:tint="@color/biru_tua"
                        android:contentDescription="Tentang" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tentang Aplikasi"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <!-- Item: Bantuan -->
                <LinearLayout
                    android:id="@+id/menuBantuan"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_help"
                        android:tint="@color/biru_tua"
                        android:contentDescription="Bantuan" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bantuan"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Garis atas tombol logout -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <!-- Tombol Logout (selalu di bawah) -->
        <LinearLayout
            android:id="@+id/menuLogout"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_power_off"
                android:tint="#E53935"
                android:contentDescription="Logout" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:textColor="#E53935"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>