<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/page_tenant_add_menu"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/toolbar_tenant_add_menu"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">

        <TextView
            android:id="@+id/btn_back_add_menu"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="Back"
            android:textColor="@color/dark_900"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_add_menu_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Tambah Menu"
            android:textColor="@color/dark_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="42dp"
            android:layout_height="42dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_add_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:id="@+id/container_add_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/upload_menu_image_area"
                android:layout_width="match_parent"
                android:layout_height="148dp"
                android:background="@drawable/bg_upload_area"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/icon_upload_menu"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_secondary_button"
                    android:gravity="center"
                    android:text="IMG"
                    android:textColor="@color/blue_700"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_upload_menu_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Upload Gambar"
                    android:textColor="@color/dark_900"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_upload_menu_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="PNG / JPG maks. 2MB"
                    android:textColor="@color/dark_700"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum ada pesanan"
                android:textColor="@color/dark_700"
                android:textSize="16sp"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/label_menu_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Nama Menu"
                android:textColor="@color/dark_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_menu_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background"
                android:hint="Masukkan nama menu"
                android:inputType="text"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:singleLine="true"
                android:textColor="@color/dark_900"
                android:textColorHint="@color/gray_400"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/label_menu_kategori"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Kategori"
                android:textColor="@color/dark_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinner_kategori"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background" />

            <TextView
                android:id="@+id/label_menu_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Harga"
                android:textColor="@color/dark_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/row_menu_price"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="14dp"
                android:paddingRight="14dp">

                <TextView
                    android:id="@+id/prefix_rupiah"
                    android:layout_width="36dp"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="Rp"
                    android:textColor="@color/dark_900"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_menu_price"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Masukkan harga"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColor="@color/dark_900"
                    android:textColorHint="@color/gray_400"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/label_menu_stock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Stok"
                android:textColor="@color/dark_900"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_menu_stock"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edit_text_background"
                android:hint="Masukkan stok"
                android:inputType="number"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:singleLine="true"
                android:textColor="@color/dark_900"
                android:textColorHint="@color/gray_400"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_save_menu"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/button_biru"
                android:gravity="center"
                android:text="Simpan Menu"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>